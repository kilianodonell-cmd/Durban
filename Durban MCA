        "# ============================================================\n",
        "# CELL 10 — Factor Scoring\n",
        "# Converts each clipped layer into a standardised 1–5 score\n",
        "# raster ready for WLC aggregation.\n",
        "#\n",
        "# Group A — Hazards:       surface reclassification\n",
        "# Group B — Infrastructure: Euclidean distance + reclassification\n",
        "# Group C — Socioeconomic:  Euclidean distance + reclassification\n",
        "#\n",
        "# Scoring direction: 1 = most suitable, 5 = least suitable\n",
        "# Only layers detected in outputs/clipped/ are scored.\n",
        "# Pending layers are skipped automatically.\n",
        "# ============================================================\n",
        "\n",
        "import rasterio\n",
        "import rasterio.features\n",
        "from rasterio.warp import reproject, Resampling, calculate_default_transform\n",
        "import numpy as np\n",
        "import geopandas as gpd\n",
        "from scipy.ndimage import distance_transform_edt\n",
        "import os\n",
        "\n",
        "CLIPPED_DIR = os.path.join(OUTPUT_ROOT, 'clipped')\n",
        "RASTERS_DIR = os.path.join(OUTPUT_ROOT, 'rasters')\n",
        "os.makedirs(RASTERS_DIR, exist_ok=True)\n",
        "\n",
        "# ============================================================\n",
        "# HELPER FUNCTIONS\n",
        "# ============================================================\n",
        "\n",
        "def get_raster_template():\n",
        "    \"\"\"Returns transform, width, height from clipped DEM as reference grid.\"\"\"\n",
        "    with rasterio.open(os.path.join(CLIPPED_DIR, 'dem.tif')) as src:\n",
        "        if str(src.crs) != TARGET_CRS:\n",
        "            transform, width, height = calculate_default_transform(\n",
        "                src.crs, TARGET_CRS, src.width, src.height, *src.bounds\n",
        "            )\n",
        "        else:\n",
        "            transform = src.transform\n",
        "            width     = src.width\n",
        "            height    = src.height\n",
        "    return transform, width, height\n",
        "\n",
        "def save_scored_raster(data, label, transform, nodata=-9999):\n",
        "    \"\"\"Save a scored 1-5 raster to outputs/rasters/\"\"\"\n",
        "    out_path = os.path.join(RASTERS_DIR, f\"scored_{label}.tif\")\n",
        "    with rasterio.open(\n",
        "        out_path, 'w',\n",
        "        driver    = 'GTiff',\n",
        "        height    = data.shape[0],\n",
        "        width     = data.shape[1],\n",
        "        count     = 1,\n",
        "        dtype     = 'float32',\n",
        "        crs       = TARGET_CRS,\n",
        "        transform = transform,\n",
        "        nodata    = nodata\n",
        "    ) as dst:\n",
        "        dst.write(data.astype('float32'), 1)\n",
        "    print(f\"  ✓ {LAYER_NAMES.get(label, label):25} → scored_{label}.tif\")\n",
        "\n",
        "def reproject_to_template(src_path, transform, width, height):\n",
        "    \"\"\"Reproject and resample raster to match AOI template grid.\"\"\"\n",
        "    with rasterio.open(src_path) as src:\n",
        "        data = np.zeros((height, width), dtype='float32')\n",
        "        reproject(\n",
        "            source         = rasterio.band(src, 1),\n",
        "            destination    = data,\n",
        "            src_transform  = src.transform,\n",
        "            src_crs        = src.crs,\n",
        "            dst_transform  = transform,\n",
        "            dst_crs        = TARGET_CRS,\n",
        "            resampling     = Resampling.nearest\n",
        "        )\n",
        "    return data\n",
        "\n",
        "def reclassify(data, breaks, nodata=-9999):\n",
        "    \"\"\"\n",
        "    Reclassify raster values into 1-5 scores.\n",
        "    breaks: list of (max_value, score) — ascending order.\n",
        "    Values above all breaks get score of last entry.\n",
        "    \"\"\"\n",
        "    result = np.full(data.shape, nodata, dtype='float32')\n",
        "    mask   = data != nodata\n",
        "    for max_val, score in breaks:\n",
        "        result[mask & (data <= max_val) & (result == nodata)] = score\n",
        "    result[mask & (result == nodata)] = breaks[-1][1]\n",
        "    return result\n",
        "\n",
        "def distance_score(gpkg_path, breaks, transform, width, height, nodata=-9999):\n",
        "    \"\"\"\n",
        "    Calculate Euclidean distance from vector features\n",
        "    then reclassify into 1-5 score using distance bands.\n",
        "    breaks: list of (max_distance_m, score) — ascending order.\n",
        "    \"\"\"\n",
        "    gdf    = gpd.read_file(gpkg_path).to_crs(TARGET_CRS)\n",
        "    shapes = [(geom, 1) for geom in gdf.geometry if geom is not None]\n",
        "    burned = rasterio.features.rasterize(\n",
        "        shapes,\n",
        "        out_shape = (height, width),\n",
        "        transform = transform,\n",
        "        fill      = 0,\n",
        "        dtype     = 'uint8'\n",
        "    )\n",
        "    pixel_size  = abs(transform[0])\n",
        "    dist_pixels = distance_transform_edt(burned == 0)\n",
        "    dist_metres = dist_pixels * pixel_size\n",
        "    result      = np.full((height, width), nodata, dtype='float32')\n",
        "    for max_dist, score in breaks:\n",
        "        result[(dist_metres <= max_dist) & (result == nodata)] = score\n",
        "    result[result == nodata] = breaks[-1][1]\n",
        "    return result\n",
        "\n",
        "# ============================================================\n",
        "# GET AOI RASTER TEMPLATE\n",
        "# ============================================================\n",
        "\n",
        "transform, width, height = get_raster_template()\n",
        "print(f\"Raster template: {width} x {height} px  CRS: {TARGET_CRS}\\n\")\n",
        "\n",
        "# ============================================================\n",
        "# GROUP A — HAZARDS\n",
        "# Surface reclassification — no distance calculation\n",
        "# ============================================================\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"  GROUP A — HAZARDS\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "# ── Landslide ────────────────────────────────────────────────\n",
        "# Already scored 1-5 by teammate. Reproject to template only.\n",
        "if LAYER_AVAILABLE['Landslide']:\n",
        "    data = reproject_to_template(\n",
        "        os.path.join(CLIPPED_DIR, 'landslide.tif'),\n",
        "        transform, width, height\n",
        "    )\n",
        "    save_scored_raster(data, 'landslide', transform)\n",
        "\n",
        "# ── Slope ────────────────────────────────────────────────────\n",
        "# Derived from DEM. Slope > 30% handled as constraint in Cell 11.\n",
        "# Here we score slope 0-30% into 1-5 bands.\n",
        "if LAYER_AVAILABLE['Slope']:\n",
        "    dem_data   = reproject_to_template(\n",
        "        os.path.join(CLIPPED_DIR, 'dem.tif'),\n",
        "        transform, width, height\n",
        "    )\n",
        "    pixel_size = abs(transform[0])\n",
        "    dz_dx      = np.gradient(dem_data, pixel_size, axis=1)\n",
        "    dz_dy      = np.gradient(dem_data, pixel_size, axis=0)\n",
        "    slope_pct  = np.tan(np.arctan(np.sqrt(dz_dx**2 + dz_dy**2))) * 100\n",
        "\n",
        "    slope_breaks = [\n",
        "        (5,  1),   # 0–5%   very flat     = most suitable\n",
        "        (10, 2),   # 5–10%  gentle\n",
        "        (15, 3),   # 10–15% moderate\n",
        "        (20, 4),   # 15–20% steep\n",
        "        (30, 5),   # 20–30% very steep    = least suitable\n",
        "    ]\n",
        "    scored_slope = reclassify(slope_pct, slope_breaks)\n",
        "    save_scored_raster(scored_slope, 'slope', transform)\n",
        "\n",
        "# ── Flood ────────────────────────────────────────────────────\n",
        "# Pending teammate — will be surface reclassification\n",
        "if LAYER_AVAILABLE['Flood']:\n",
        "    data = reproject_to_template(\n",
        "        os.path.join(CLIPPED_DIR, 'flood.tif'),\n",
        "        transform, width, height\n",
        "    )\n",
        "    save_scored_raster(data, 'flood', transform)\n",
        "\n",
        "# ── Community hazard map ─────────────────────────────────────\n",
        "# Pending stakeholder — will be surface reclassification\n",
        "if LAYER_AVAILABLE['Community']:\n",
        "    data = reproject_to_template(\n",
        "        os.path.join(CLIPPED_DIR, 'community.tif'),\n",
        "        transform, width, height\n",
        "    )\n",
        "    save_scored_raster(data, 'community', transform)\n",
        "\n",
        "# ============================================================\n",
        "# GROUP B — INFRASTRUCTURE\n",
        "# Euclidean distance scoring\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(\"  GROUP B — INFRASTRUCTURE\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "# ── Roads ────────────────────────────────────────────────────\n",
        "# 1=0-100m, 2=100-300m, 3=300-600m, 4=600-1000m, 5=>1000m\n",
        "if LAYER_AVAILABLE['Roads']:\n",
        "    roads_breaks = [\n",
        "        (100,  1),\n",
        "        (300,  2),\n",
        "        (600,  3),\n",
        "        (1000, 4),\n",
        "        (9999, 5),\n",
        "    ]\n",
        "    data = distance_score(\n",
        "        os.path.join(CLIPPED_DIR, 'roads.gpkg'),\n",
        "        roads_breaks, transform, width, height\n",
        "    )\n",
        "    save_scored_raster(data, 'roads', transform)\n",
        "\n",
        "# ── Health facilities ────────────────────────────────────────\n",
        "# 1=0-500m, 2=500-2000m, 3=2000-4000m, 4=4000-8000m, 5=>8000m\n",
        "if LAYER_AVAILABLE['Health']:\n",
        "    health_breaks = [\n",
        "        (500,  1),\n",
        "        (2000, 2),\n",
        "        (4000, 3),\n",
        "        (8000, 4),\n",
        "        (9999, 5),\n",
        "    ]\n",
        "    data = distance_score(\n",
        "        os.path.join(CLIPPED_DIR, 'health_facilities.gpkg'),\n",
        "        health_breaks, transform, width, height\n",
        "    )\n",
        "    save_scored_raster(data, 'health', transform)\n",
        "\n",
        "# ── Fire stations ────────────────────────────────────────────\n",
        "# 1=0-500m, 2=500-2000m, 3=2000-4000m, 4=4000-8000m, 5=>8000m\n",
        "if LAYER_AVAILABLE['Fire']:\n",
        "    fire_breaks = [\n",
        "        (500,  1),\n",
        "        (2000, 2),\n",
        "        (4000, 3),\n",
        "        (8000, 4),\n",
        "        (9999, 5),\n",
        "    ]\n",
        "    data = distance_score(\n",
        "        os.path.join(CLIPPED_DIR, 'fire.gpkg'),\n",
        "        fire_breaks, transform, width, height\n",
        "    )\n",
        "    save_scored_raster(data, 'fire', transform)\n",
        "\n",
        "# ── Water network ────────────────────────────────────────────\n",
        "# 1=0-100m, 2=100-300m, 3=300-600m, 4=600-1000m, 5=>1000m\n",
        "if LAYER_AVAILABLE['Water']:\n",
        "    water_breaks = [\n",
        "        (100,  1),\n",
