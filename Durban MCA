        "# ============================================================\n",
        "# CELL 11 — Constraint Mask\n",
        "# Builds a binary raster mask from environmental constraint\n",
        "# layers. Cells inside constrained areas are set to 0\n",
        "# (excluded). All other cells are set to 1 (buildable).\n",
        "#\n",
        "# Constraints applied:\n",
        "#   - Slope > 30%\n",
        "#   - D'MOSS areas\n",
        "#   - River buffer (RIVER_BUFFER_M defined in Cell 2)\n",
        "#   - Wetlands (pending)\n",
        "#\n",
        "# The mask is applied to all scored rasters before WLC.\n",
        "# Change RIVER_BUFFER_M in Cell 2 to adjust river buffer.\n",
        "# ============================================================\n",
        "\n",
        "import rasterio\n",
        "import rasterio.features\n",
        "import numpy as np\n",
        "import geopandas as gpd\n",
        "from rasterio.warp import reproject, Resampling, calculate_default_transform\n",
        "import os\n",
        "\n",
        "CLIPPED_DIR = os.path.join(OUTPUT_ROOT, 'clipped')\n",
        "RASTERS_DIR = os.path.join(OUTPUT_ROOT, 'rasters')\n",
        "\n",
        "# ── Get raster template ──────────────────────────────────────\n",
        "def get_raster_template():\n",
        "    with rasterio.open(os.path.join(CLIPPED_DIR, 'dem.tif')) as src:\n",
        "        if str(src.crs) != TARGET_CRS:\n",
        "            transform, width, height = calculate_default_transform(\n",
        "                src.crs, TARGET_CRS, src.width, src.height, *src.bounds\n",
        "            )\n",
        "        else:\n",
        "            transform = src.transform\n",
        "            width     = src.width\n",
        "            height    = src.height\n",
        "    return transform, width, height\n",
        "\n",
        "transform, width, height = get_raster_template()\n",
        "\n",
        "# ── Initialise mask — all cells buildable ────────────────────\n",
        "mask = np.ones((height, width), dtype='uint8')\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"  CELL 11 — CONSTRAINT MASK\")\n",
        "print(\"=\" * 60)\n",
        "print(f\"\\n  Raster template: {width} x {height} px\")\n",
        "print(f\"  Initial buildable cells: {mask.sum():,}\\n\")\n",
        "\n",
        "# ── Helper: burn vector constraint ──────────────────────────\n",
        "def apply_vector_constraint(gpkg_path, label, mask, buffer_m=None):\n",
        "    \"\"\"Set cells inside vector features to 0 (excluded).\"\"\"\n",
        "    gdf = gpd.read_file(gpkg_path).to_crs(TARGET_CRS)\n",
        "    if buffer_m:\n",
        "        gdf = gdf.copy()\n",
        "        gdf['geometry'] = gdf.geometry.buffer(buffer_m)\n",
        "    shapes  = [(geom, 1) for geom in gdf.geometry if geom is not None]\n",
        "    burned  = rasterio.features.rasterize(\n",
        "        shapes,\n",
        "        out_shape = (height, width),\n",
        "        transform = transform,\n",
        "        fill      = 0,\n",
        "        dtype     = 'uint8'\n",
        "    )\n",
        "    excluded = int((burned == 1).sum())\n",
        "    mask[burned == 1] = 0\n",
        "    buf_note = f\" (buffer: {buffer_m}m)\" if buffer_m else \"\"\n",
        "    print(f\"  ✓ {label:30} excluded: {excluded:,} cells{buf_note}\")\n",
        "    return mask\n",
        "\n",
        "# ── Helper: burn raster constraint ──────────────────────────\n",
        "def apply_raster_constraint(tif_path, label, mask, threshold, above=True):\n",
        "    \"\"\"\n",
        "    Set cells to 0 where raster value is above (or below) threshold.\n",
        "    above=True: exclude where value > threshold\n",
        "    above=False: exclude where value < threshold\n",
        "    \"\"\"\n",
        "    with rasterio.open(tif_path) as src:\n",
        "        data = np.zeros((height, width), dtype='float32')\n",
        "        reproject(\n",
        "            source        = rasterio.band(src, 1),\n",
        "            destination   = data,\n",
        "            src_transform = src.transform,\n",
        "            src_crs       = src.crs,\n",
        "            dst_transform = transform,\n",
        "            dst_crs       = TARGET_CRS,\n",
        "            resampling    = Resampling.bilinear\n",
