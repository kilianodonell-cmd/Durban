        "\n",
        "    'wetlands': {\n",
        "        'label'  : 'Wetlands',\n",
        "        'path'   : os.path.join(GRP_E, 'wetlands.gpkg'),\n",
        "        'buffer' : None,\n",
        "        'clipped': 'wetlands.gpkg',\n",
        "        'type'   : 'vector',\n",
        "    },\n",
        "\n",
        "}\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "# ── Health source layers (merged into Health in Cell 5) ──────\n",
        "HEALTH_SOURCES = {\n",
        "    'Fixed Clinics' : os.path.join(GRP_B, 'Fixed_Clinics_9054252116514405220.gpkg'),\n",
