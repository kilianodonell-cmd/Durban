        "# ============================================================\n",
        "# CELL 5 — Clip All Layers to AOI\n",
        "# Reads LAYER_GROUPS from Cell 2 config.\n",
        "# Add new layers in Cell 2 only — nothing to change here.\n",
        "# ============================================================\n",
        "\n",
        "import geopandas as gpd\n",
        "import rasterio\n",
        "from rasterio.mask import mask as rasterio_mask\n",
        "import pandas as pd\n",
        "import json\n",
        "import warnings\n",
        "import os\n",
        "\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "CLIPPED_DIR = os.path.join(OUTPUT_ROOT, 'clipped')\n",
        "os.makedirs(CLIPPED_DIR, exist_ok=True)\n",
        "\n",
        "print(\"Clipping layers to AOI...\")\n",
        "print(f\"  AOI: {LAYER_NAMES['aoi']}\\n\")\n",
        "\n",
        "def clip_vector_layer(path, key, aoi_geom, buffer=None):\n",
        "    gdf     = gpd.read_file(path).to_crs(TARGET_CRS)\n",
        "    clip_to = aoi_geom.buffer(buffer) if buffer else aoi_geom\n",
        "    clipped = gpd.clip(gdf, clip_to)\n",
        "    out     = os.path.join(CLIPPED_DIR, f\"{key}.gpkg\")\n",
        "    clipped.to_file(out, driver='GPKG')\n",
        "    buf_note = f\" (buffer: {buffer}m)\" if buffer else \"\"\n",
        "    print(f\"  ✓ {LAYER_NAMES.get(key, key):30} — {len(clipped)} features → {key}.gpkg{buf_note}\")\n",
        "    return clipped\n",
        "\n",
        "def clip_raster_layer(path, key, aoi_geom):\n",
        "    with rasterio.open(path) as src:\n",
        "        aoi_proj = aoi_geom.to_crs(src.crs) if hasattr(aoi_geom, 'crs') else aoi_geom\n",
        "        shapes   = [json.loads(aoi_proj.geometry.to_json())['features'][0]['geometry']]\n",
        "        out_img, out_transform = rasterio_mask(src, shapes, crop=True)\n",
        "        out_meta = src.meta.copy()\n",
        "        out_meta.update({\n",
        "            'driver': 'GTiff', 'height': out_img.shape[1],\n",
        "            'width': out_img.shape[2], 'transform': out_transform,\n",
        "        })\n",
        "    out = os.path.join(CLIPPED_DIR, f\"{key}.tif\")\n",
        "    with rasterio.open(out, 'w', **out_meta) as dst:\n",
