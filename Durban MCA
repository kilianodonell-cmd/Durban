        "        scoring = [(50,1),(200,2),(500,3),(1000,4),(9999,5)],\n",
        "    ),\n",
        "\n",
        "    'Tracks': new_factor(\n",
        "        group   = 'Infrastructure',\n",
        "        label   = 'Tracks',\n",
