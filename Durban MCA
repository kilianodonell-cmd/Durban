        "import numpy as np\n",
        "\n",
        "# ── Fuzzy scale conversion ───────────────────────────────────\n",
        "FUZZY_SCALE = {\n",
        "    1: (1, 1, 1),\n",
        "    2: (1, 2, 3),\n",
        "    3: (2, 3, 4),\n",
        "    4: (3, 4, 5),\n",
        "    5: (4, 5, 6),\n",
        "    6: (5, 6, 7),\n",
