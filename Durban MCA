        "# ── AHP functions ────────────────────────────────────────────\n",
        "def build_matrix(factors, comparisons):\n",
        "    \"\"\"\n",
        "    Build pairwise comparison matrix from recorded judgements.\n",
        "    comparisons: list of tuples (i, j, score)\n",
        "      where score > 0 means factor[i] is more important\n",
        "      and score < 0 means factor[j] is more important\n",
        "    \"\"\"\n",
        "    n = len(factors)\n",
        "    matrix = np.ones((n, n))\n",
        "    idx = {f: i for i, f in enumerate(factors)}\n",
        "    for i, j, score in comparisons:\n",
        "        matrix[idx[i]][idx[j]] = score\n",
        "        matrix[idx[j]][idx[i]] = 1 / score\n",
        "    return matrix\n",
        "\n",
        "def calculate_weights(matrix):\n",
        "    \"\"\"Calculate priority vector (weights) from pairwise matrix.\"\"\"\n",
