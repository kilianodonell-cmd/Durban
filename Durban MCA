        "# ============================================================\n",
        "# CELL 5 — Clip All Layers to AOI\n",
        "# Vector layers clipped to AOI or buffered AOI depending\n",
        "# on the largest scoring distance band for that layer.\n",
        "# Rasters clipped to AOI extent.\n",
        "# ============================================================\n",
        "\n",
        "import geopandas as gpd\n",
        "import rasterio\n",
        "from rasterio.mask import mask\n",
        "import json\n",
        "import warnings\n",
        "import os\n",
        "\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "CLIPPED_DIR = os.path.join(OUTPUT_ROOT, 'clipped')\n",
        "os.makedirs(CLIPPED_DIR, exist_ok=True)\n",
        "\n",
        "# ── Pre-compute buffered AOIs ────────────────────────────────\n",
        "aoi_buf = {}\n",
        "for layer, dist in BUFFERS.items():\n",
        "    aoi_buf[layer] = aoi.buffer(dist).to_frame('geometry').set_crs(TARGET_CRS)\n",
        "\n",
        "# ── Clip vector ──────────────────────────────────────────────\n",
        "def clip_vector(path, label, clip_geom):\n",
        "    gdf     = gpd.read_file(path).to_crs(TARGET_CRS)\n",
        "    clipped = gpd.clip(gdf, clip_geom)\n",
        "    out_path = os.path.join(CLIPPED_DIR, f\"{label}.gpkg\")\n",
        "    clipped.to_file(out_path, driver='GPKG')\n",
        "    buf_note = f\" (buffer: {BUFFERS[label]}m)\" if label in BUFFERS else \"\"\n",
        "    print(f\"  ✓ {LAYER_NAMES[label]} — {len(clipped)} features → {label}.gpkg{buf_note}\")\n",
        "    return clipped\n",
        "\n",
        "# ── Clip raster ──────────────────────────────────────────────\n",
        "def clip_raster(path, label, clip_geom):\n",
        "    with rasterio.open(path) as src:\n",
        "        aoi_raster_crs = clip_geom.to_crs(src.crs)\n",
        "        shapes = [json.loads(aoi_raster_crs.geometry.to_json())['features'][0]['geometry']]\n",
