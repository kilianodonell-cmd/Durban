      "source": [
        "# ============================================================\n",
        "# CELL 12 — Weighted Linear Combination (WLC)\n",
        "# Applies FAHP weights to scored rasters and produces:\n",
        "#   1. One suitability map per group\n",
        "#   2. Final combined suitability map\n",
        "#\n",
        "# Constraint mask applied before aggregation.\n",
        "# Only available layers included — auto-detected from\n",
        "# FINAL_WEIGHTS_BUCKLEY in Cell 9.\n",
        "#\n",
        "# Reference: Malczewski (1999), WLC equation:\n",
        "#   S = Σ(wi * xi) * constraint_mask\n",
        "# ============================================================\n",
        "\n",
        "import rasterio\n",
        "import rasterio.features\n",
        "from rasterio.warp import reproject, Resampling, calculate_default_transform\n",
        "from rasterio.plot import plotting_extent\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import os\n",
        "\n",
        "CLIPPED_DIR = os.path.join(OUTPUT_ROOT, 'clipped')\n",
        "RASTERS_DIR = os.path.join(OUTPUT_ROOT, 'rasters')\n",
        "MAPS_DIR    = os.path.join(OUTPUT_ROOT, 'maps')\n",
        "\n",
        "# ============================================================\n",
        "# SETUP\n",
        "# ============================================================\n",
        "\n",
        "# ── Raster template ──────────────────────────────────────────\n",
        "def get_raster_template():\n",
        "    with rasterio.open(os.path.join(CLIPPED_DIR, 'dem.tif')) as src:\n",
        "        if str(src.crs) != TARGET_CRS:\n",
        "            transform, width, height = calculate_default_transform(\n",
        "                src.crs, TARGET_CRS, src.width, src.height, *src.bounds\n",
        "            )\n",
        "        else:\n",
        "            transform = src.transform\n",
        "            width     = src.width\n",
        "            height    = src.height\n",
        "    return transform, width, height\n",
        "\n",
        "transform, width, height = get_raster_template()\n",
        "\n",
        "# ── AOI raster mask ──────────────────────────────────────────\n",
        "# Pixels outside AOI = 0, inside AOI = 1\n",
        "aoi_raster_mask = rasterio.features.rasterize(\n",
        "    [(geom, 1) for geom in aoi.to_crs(TARGET_CRS).geometry],\n",
        "    out_shape = (height, width),\n",
        "    transform = transform,\n",
        "    fill      = 0,\n",
        "    dtype     = 'uint8'\n",
        ")\n",
        "\n",
        "# ── Constraint mask ──────────────────────────────────────────\n",
        "# Pixels inside constraints = 0, buildable = 1\n",
        "with rasterio.open(os.path.join(RASTERS_DIR, 'constraint_mask.tif')) as src:\n",
        "    constraint_mask = src.read(1).astype('float32')\n",
        "\n",
        "# ── Combined mask ────────────────────────────────────────────\n",
        "# Pixels must be inside AOI AND not constrained\n",
        "# 1 = buildable, NaN = excluded or outside AOI\n",
        "combined_mask = np.where(\n",
        "    (aoi_raster_mask == 1) & (constraint_mask == 1),\n",
        "    1.0, np.nan\n",
        ")\n",
        "\n",
        "# ============================================================\n",
        "# HELPER FUNCTIONS\n",
        "# ============================================================\n",
        "\n",
        "def load_scored(filename):\n",
        "    \"\"\"Load scored raster and reproject to template grid.\"\"\"\n",
        "    path = os.path.join(RASTERS_DIR, filename)\n",
        "    with rasterio.open(path) as src:\n",
        "        data = np.zeros((height, width), dtype='float32')\n",
        "        reproject(\n",
        "            source        = rasterio.band(src, 1),\n",
        "            destination   = data,\n",
        "            src_transform = src.transform,\n",
        "            src_crs       = src.crs,\n",
        "            dst_transform = transform,\n",
        "            dst_crs       = TARGET_CRS,\n",
        "            resampling    = Resampling.nearest\n",
        "        )\n",
        "    data[data <= 0] = np.nan\n",
        "    return data\n",
        "\n",
        "def save_suitability(data, filename):\n",
        "    \"\"\"Save suitability raster to outputs/rasters/\"\"\"\n",
        "    path = os.path.join(RASTERS_DIR, filename)\n",
        "    with rasterio.open(\n",
        "        path, 'w',\n",
        "        driver    = 'GTiff',\n",
        "        height    = height,\n",
        "        width     = width,\n",
        "        count     = 1,\n",
        "        dtype     = 'float32',\n",
        "        crs       = TARGET_CRS,\n",
        "        transform = transform,\n",
        "        nodata    = np.nan\n",
        "    ) as dst:\n",
        "        dst.write(data, 1)\n",
        "    return path\n",
        "\n",
        "def plot_suitability(data, title, filename):\n",
        "    \"\"\"\n",
        "    Plot suitability map zoomed to AOI.\n",
        "    - Inside AOI + buildable: coloured by score 1-5\n",
        "    - Inside AOI + constrained: white\n",
        "    - Outside AOI: white\n",
        "    \"\"\"\n",
        "    minx, miny, maxx, maxy = aoi.total_bounds\n",
        "    buf = (maxx - minx) * 0.05\n",
        "\n",
        "    fig, ax = plt.subplots(figsize=(8, 8))\n",
        "    ax.set_facecolor('white')\n",
        "    fig.patch.set_facecolor('white')\n",
        "\n",
        "    # Get raster extent\n",
        "    with rasterio.open(os.path.join(RASTERS_DIR, filename)) as src:\n",
        "        extent = plotting_extent(src)\n",
        "\n",
        "    # Apply AOI mask to plot data — outside AOI = NaN = white\n",
        "    plot_data = data.copy()\n",
        "    plot_data[aoi_raster_mask == 0] = np.nan\n",
        "\n",
        "    # Plot raster\n",
        "    im = ax.imshow(\n",
        "        plot_data,\n",
        "        cmap   = 'RdYlGn_r',\n",
        "        vmin   = 1,\n",
        "        vmax   = 5,\n",
        "        extent = extent,\n",
        "        origin = 'upper'\n",
        "    )\n",
        "\n",
        "    # AOI boundary\n",
        "    aoi.to_crs(TARGET_CRS).boundary.plot(\n",
        "        ax        = ax,\n",
        "        color     = 'black',\n",
        "        linewidth = 1.5\n",
        "    )\n",
        "\n",
        "    # Zoom to AOI\n",
        "    ax.set_xlim(minx - buf, maxx + buf)\n",
        "    ax.set_ylim(miny - buf, maxy + buf)\n",
        "\n",
        "    # Colourbar and labels\n",
        "    cbar = plt.colorbar(im, ax=ax, shrink=0.8)\n",
        "    cbar.set_label('1 = Highly Suitable    5 = Unsuitable', fontsize=9)\n",
        "    cbar.set_ticks([1, 2, 3, 4, 5])\n",
        "    cbar.set_ticklabels(['1 Highly suitable', '2 Suitable',\n",
        "                         '3 Moderate', '4 Unsuitable', '5 Highly unsuitable'])\n",
        "\n",
        "    ax.set_title(title, fontsize=12)\n",
        "    ax.set_xlabel('Easting (m)', fontsize=9)\n",
        "    ax.set_ylabel('Northing (m)', fontsize=9)\n",
        "    ax.grid(True, alpha=0.3)\n",
        "    plt.tight_layout()\n",
        "\n",
        "    out_path = os.path.join(MAPS_DIR, filename.replace('.tif', '.png'))\n",
        "    plt.savefig(out_path, dpi=300, bbox_inches='tight')\n",
        "    print(f\"  ✓ Map saved → {filename.replace('.tif', '.png')}\")\n",
        "    plt.show()\n",
        "\n",
        "# ── Factor to scored raster filename mapping ─────────────────\n",
        "FACTOR_FILES = {\n",
        "    'Flood'              : 'scored_flood.tif',\n",
        "    'Landslide'          : 'scored_landslide.tif',\n",
        "    'Slope'              : 'scored_slope.tif',\n",
        "    'Community'          : 'scored_community.tif',\n",
        "    'Primary roads'      : 'scored_roads_primary.tif',\n",
        "    'Secondary roads'    : 'scored_roads_secondary.tif',\n",
        "    'Tracks'             : 'scored_roads_tracks.tif',\n",
        "    'Water'              : 'scored_water.tif',\n",
        "    'Electricity'        : 'scored_electricity.tif',\n",
        "    'Health'             : 'scored_health.tif',\n",
        "    'Fire'               : 'scored_fire.tif',\n",
        "    'Investment nodes'   : 'scored_investment.tif',\n",
        "    'Transport corridors': 'scored_transport.tif',\n",
        "    'Settlements'        : 'scored_settlements.tif',\n",
        "}\n",
        "\n",
        "# ── Group factor membership ──────────────────────────────────\n",
        "GROUP_FACTORS = {\n",
        "    'Hazards'        : ['Flood', 'Landslide', 'Slope', 'Community'],\n",
        "    'Infrastructure' : ['Primary roads', 'Secondary roads', 'Tracks',\n",
        "                        'Water', 'Electricity', 'Health', 'Fire'],\n",
        "    'Socioeconomic'  : ['Investment nodes', 'Transport corridors', 'Settlements'],\n",
        "}\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"  CELL 12 — WEIGHTED LINEAR COMBINATION\")\n",
        "print(\"=\" * 60)\n",
        "print(f\"\\n  AOI mask:        {int(aoi_raster_mask.sum()):,} cells inside AOI\")\n",
        "print(f\"  Buildable cells: {int((combined_mask == 1).sum()):,} cells after constraints\")\n",
        "\n",
        "# ============================================================\n",
        "# STEP 1 — GROUP SUITABILITY MAPS\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n  Step 1 — Group suitability maps\")\n",
        "print(\"  \" + \"-\" * 40)\n",
        "\n",
        "group_maps = {}\n",
        "\n",
        "for group_name, factors in GROUP_FACTORS.items():\n",
        "\n",
        "    # Get available factors with weights\n",
        "    available = {\n",
        "        f: ACTIVE_WEIGHTS[f]\n",
        "        for f in factors\n",
        "        if f in ACTIVE_WEIGHTS and\n",
        "        os.path.exists(os.path.join(RASTERS_DIR, FACTOR_FILES[f]))\n",
        "    }\n",
        "\n",
        "    if not available:\n",
        "        print(f\"\\n  {group_name}: no layers available — skipped\")\n",
        "        continue\n",
        "\n",
        "    print(f\"\\n  {group_name}:\")\n",
        "\n",
        "    # Renormalise weights within group\n",
        "    total_w = sum(available.values())\n",
        "    norm_w  = {f: w/total_w for f, w in available.items()}\n",
        "\n",
        "    # Weighted sum\n",
        "    group_map = np.zeros((height, width), dtype='float32')\n",
        "    for factor, weight in norm_w.items():\n",
        "        data       = load_scored(FACTOR_FILES[factor])\n",
        "        group_map += weight * np.nan_to_num(data, nan=0)\n",
        "        print(f\"    {factor:25} weight: {weight:.4f}  ({weight*100:.1f}%)\")\n",
        "\n",
        "    # Apply combined mask\n",
        "    group_map = group_map * combined_mask\n",
        "\n",
        "    # Save and plot\n",
        "    filename = f\"suitability_{group_name.lower().replace(' ', '_')}.tif\"\n",
        "    save_suitability(group_map, filename)\n",
        "    group_maps[group_name] = group_map\n",
        "\n",
        "    plot_suitability(\n",
        "        group_map,\n",
        "        f'{group_name} Suitability Map\\n{LAYER_NAMES[\"aoi\"]}',\n",
        "        filename\n",
        "    )\n",
        "\n",
        "# ============================================================\n",
        "# STEP 2 — FINAL COMBINED SUITABILITY MAP\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n  Step 2 — Final combined suitability map\")\n",
        "print(\"  \" + \"-\" * 40)\n",
        "\n",
        "# Group level weights from Cell 9\n",
        "group_level_weights = {\n",
        "    f: w for f, w in zip(group_factors, group_weights)\n",
        "}\n",
        "\n",
        "# Only include groups that have maps\n",
        "available_groups = {\n",
        "    g: group_level_weights[g]\n",
        "    for g in group_maps\n",
        "    if g in group_level_weights\n",
        "}\n",
        "\n",
        "# Renormalise\n",
        "total_gw  = sum(available_groups.values())\n",
        "norm_gw   = {g: w/total_gw for g, w in available_groups.items()}\n",
        "\n",
        "final_map = np.zeros((height, width), dtype='float32')\n",
        "for group_name, weight in norm_gw.items():\n",
        "    final_map += weight * np.nan_to_num(group_maps[group_name], nan=0)\n",
        "    print(f\"    {group_name:25} weight: {weight:.4f}  ({weight*100:.1f}%)\")\n",
        "\n",
        "# Apply combined mask\n",
        "final_map = final_map * combined_mask\n",
        "\n",
        "# Save and plot\n",
        "save_suitability(final_map, 'suitability_final.tif')\n",
        "plot_suitability(\n",
        "    final_map,\n",
        "    f'Final Housing Suitability Map\\n{LAYER_NAMES[\"aoi\"]}',\n",
        "    'suitability_final.tif'\n",
        ")\n",
        "\n",
        "# ============================================================\n",
        "# SUMMARY\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(\"  WLC COMPLETE\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "buildable   = ~np.isnan(final_map)\n",
        "total_build = buildable.sum()\n",
        "\n",
        "print(f\"\\n  Suitability distribution (buildable cells only):\")\n",
        "for score, label in [(1, 'Highly suitable'), (2, 'Suitable'),\n",
        "                     (3, 'Moderate'),        (4, 'Unsuitable'),\n",
        "                     (5, 'Highly unsuitable')]:\n",
        "    count = int(((final_map >= score - 0.5) &\n",
        "                 (final_map < score + 0.5) & buildable).sum())\n",
        "    pct   = count / total_build * 100 if total_build > 0 else 0\n",
        "    bar   = \"█\" * int(pct / 2)\n",
        "    print(f\"    Score {score} — {label:20} {count:6,} cells  ({pct:5.1f}%)  {bar}\")\n",
        "\n",
        "print(f\"\\n  ✓ Group maps saved to outputs/rasters/\")\n",
        "print(f\"  ✓ Final map saved → suitability_final.tif\")\n",
        "print(f\"  ✓ Maps saved to outputs/maps/\")"
      ],
