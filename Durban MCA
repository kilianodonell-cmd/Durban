        "    n = len(factors)\n",
        "    idx = {f: i for i, f in enumerate(factors)}\n",
        "    # Initialise with (1,1,1) on diagonal\n",
        "    matrix = [[(1,1,1) for _ in range(n)] for _ in range(n)]\n",
        "    for i, j, score in comparisons:\n",
        "        tfn = FUZZY_SCALE[score]\n",
