        "    col_sums = matrix.sum(axis=0)\n",
        "    normalised = matrix / col_sums\n",
        "    # Priority vector = row means\n",
        "    weights = normalised.mean(axis=1)\n",
        "    return weights\n",
        "\n",
        "def consistency_ratio(matrix, weights):\n",
        "    \"\"\"Calculate Consistency Ratio (CR). Must be ≤ 0.10.\"\"\"\n",
        "    n = len(weights)\n",
        "    lambda_max = (matrix @ weights / weights).mean()\n",
        "    CI = (lambda_max - n) / (n - 1)\n",
        "    CR = CI / RI[n] if RI[n] > 0 else 0\n",
