        "# CELL 8 — Fuzzy AHP Weights\n",
        "# Applies Fuzzy Analytic Hierarchy Process (FAHP) to derive\n",
        "# criteria weights from the pairwise comparisons recorded in\n",
        "# Cell 7. Fuzzy triangular numbers replace crisp AHP scores\n",
        "# to account for uncertainty in expert judgement.\n",
        "#\n",
        "# Triangular fuzzy scale (Sisman & Aydinoglu, 2020):\n",
        "#   1 → (1,1,1)  3 → (2,3,4)  5 → (4,5,6)\n",
        "#   7 → (6,7,8)  9 → (9,9,9)\n",
        "#\n",
        "# Method: Chang (1996) extent analysis\n",
        "# ============================================================\n",
        "\n",
        "import numpy as np\n",
        "\n",
        "# ── Fuzzy scale conversion ───────────────────────────────────\n",
        "FUZZY_SCALE = {\n",
        "    1: (1, 1, 1),\n",
        "    2: (1, 2, 3),\n",
        "    3: (2, 3, 4),\n",
        "    4: (3, 4, 5),\n",
        "    5: (4, 5, 6),\n",
        "    6: (5, 6, 7),\n",
        "    7: (6, 7, 8),\n",
        "    8: (7, 8, 9),\n",
        "    9: (9, 9, 9),\n",
        "}\n",
        "\n",
        "def reciprocal_fuzzy(tfn):\n",
        "    \"\"\"Return reciprocal of a triangular fuzzy number.\"\"\"\n",
        "    l, m, u = tfn\n",
        "    return (1/u, 1/m, 1/l)\n",
        "\n",
        "def build_fuzzy_matrix(factors, comparisons):\n",
        "    \"\"\"\n",
        "    Build fuzzy pairwise comparison matrix.\n",
        "    comparisons: list of (factor_i, factor_j, crisp_score)\n",
        "    positive score = factor_i more important\n",
        "    negative score = factor_j more important (use positive, order matters)\n",
        "    \"\"\"\n",
        "    n = len(factors)\n",
        "    idx = {f: i for i, f in enumerate(factors)}\n",
        "    # Initialise with (1,1,1) on diagonal\n",
        "    matrix = [[(1,1,1) for _ in range(n)] for _ in range(n)]\n",
        "    for i, j, score in comparisons:\n",
        "        tfn = FUZZY_SCALE[score]\n",
        "        matrix[idx[i]][idx[j]] = tfn\n",
        "        matrix[idx[j]][idx[i]] = reciprocal_fuzzy(tfn)\n",
        "    return matrix\n",
        "\n",
        "def fuzzy_synthetic_extent(matrix):\n",
        "    \"\"\"\n",
        "    Calculate fuzzy synthetic extent values for each factor.\n",
        "    Returns list of (l, m, u) per factor.\n",
        "    \"\"\"\n",
        "    n = len(matrix)\n",
        "    # Row sums\n",
        "    row_sums = []\n",
        "    for i in range(n):\n",
        "        l = sum(matrix[i][j][0] for j in range(n))\n",
        "        m = sum(matrix[i][j][1] for j in range(n))\n",
        "        u = sum(matrix[i][j][2] for j in range(n))\n",
        "        row_sums.append((l, m, u))\n",
        "    # Total sum\n",
        "    total_l = sum(r[0] for r in row_sums)\n",
        "    total_m = sum(r[1] for r in row_sums)\n",
        "    total_u = sum(r[2] for r in row_sums)\n",
        "    # Synthetic extent = row_sum * reciprocal of total\n",
        "    extents = []\n",
        "    for l, m, u in row_sums:\n",
        "        extents.append((l/total_u, m/total_m, u/total_l))\n",
        "    return extents\n",
        "\n",
        "def degree_of_possibility(M2, M1):\n",
        "    \"\"\"\n",
        "    Degree of possibility that M2 >= M1.\n",
        "    M1, M2 are triangular fuzzy numbers (l, m, u).\n",
        "    \"\"\"\n",
        "    l1, m1, u1 = M1\n",
        "    l2, m2, u2 = M2\n",
        "    if m2 >= m1:\n",
        "        return 1.0\n",
        "    elif u1 <= l2:\n",
        "        return 0.0\n",
        "    else:\n",
        "        return (u1 - m2) / ((u1 - m2) + (m1 - l1))\n",
        "\n",
        "def fahp_weights(factors, comparisons):\n",
        "    \"\"\"\n",
        "    Calculate FAHP weights using Chang (1996) extent analysis.\n",
        "    Returns normalised weight vector.\n",
        "    \"\"\"\n",
        "    matrix  = build_fuzzy_matrix(factors, comparisons)\n",
        "    extents = fuzzy_synthetic_extent(matrix)\n",
        "    n       = len(factors)\n",
        "\n",
        "    # Degree of possibility for each factor over all others\n",
        "    weights = []\n",
        "    for i in range(n):\n",
        "        min_val = min(\n",
        "            degree_of_possibility(extents[i], extents[j])\n",
        "            for j in range(n) if j != i\n",
        "        )\n",
        "        weights.append(min_val)\n",
        "\n",
        "    # Normalise\n",
        "    total = sum(weights)\n",
        "    if total == 0:\n",
        "        weights = [1/n] * n\n",
        "    else:\n",
        "        weights = [w/total for w in weights]\n",
        "\n",
        "    return np.array(weights)\n",
