        "\n",
        "# ── Settlements ──────────────────────────────────────────────\n",
        "# 1=0-100m, 2=100-500m, 3=500-1000m, 4=1000-3000m, 5=>3000m\n",
        "if LAYER_AVAILABLE['Settlements']:\n",
        "    settlements_breaks = [\n",
        "        (100,  1),\n",
        "        (500,  2),\n",
        "        (1000, 3),\n",
        "        (3000, 4),\n",
        "        (9999, 5),\n",
        "    ]\n",
        "    data = distance_score(\n",
        "        os.path.join(CLIPPED_DIR, 'settlements.gpkg'),\n",
